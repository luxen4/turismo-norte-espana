    #Ibarrangelu
    RewriteRule ^ibarrangelu-bizkaia$ /bizkaia/ibarrangelu/index.php [L]

    RewriteRule ^lugares-interes/playa-de-laga-ibarrangelu$ /bizkaia/ibarrangelu/lugares-interes/playa-de-laga/index.php [L]
