    RewriteRule ^lugares-interes/ojo-del-diablo-sonabia$        cantabria/sonabia/lugares-interes/ojo-del-diablo/index.php [L]
    


    # Santoña
    RewriteRule ^santona-cantabria$             cantabria/santona/index.php [L]

    RewriteRule ^lugares-interes/santona-cantabria$ cantabria/santona/index.php [L]


    RewriteRule ^lugares-interes/playa-de-berria-santona$ cantabria/santona/lugares-interes/playa-de-berria/index.php [L]

    RewriteRule ^lugares-interes/monte-buciero-santona$     cantabria/santona/lugares-interes/monte-buciero/index.php [L]
    RewriteRule ^lugares-interes/faro-del-caballo-santona$  cantabria/santona/lugares-interes/faro-del-caballo/index.php [L]
    RewriteRule ^lugares-interes/puerto-de-santona-santona$         cantabria/santona/lugares-interes/puerto-de-santona/index.php [L]




    # Berria
    #RewriteRule ^playa-de-berria-santona-cantabria$ cantabria/playadeberria/fichas/playa-de-berria-santona-cantabria.php [L]
    RewriteRule ^actividades-playa-de-berria-santona-cantabria$ cantabria/playadeberria/paginas_secundarias/actividades-playa-de-berria-santona-cantabria.php [L]
    RewriteRule ^como-llegar-playa-de-berria-santona-cantabria$ cantabria/playadeberria/paginas_secundarias/como-llegar-playa-de-berria-santona-cantabria.php [L]
    RewriteRule ^servicios-playa-de-berria-santona-cantabria$ cantabria/playadeberria/paginas_secundarias/servicios-playa-de-berria-santona-cantabria.php [L]
    RewriteRule ^eventos-festividades-playa-de-berria-santona-cantabria$ cantabria/playadeberria/paginas_secundarias/eventos-festividades-playa-de-berria-santona-cantabria.php [L]
