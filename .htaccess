    RewriteRule ^lugares-interes/playa-el-pedregal-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/playa-el-pedregal/index.php [L]    
    RewriteRule ^lugares.interes/iglesia-santa-maria-de-la-asuncion-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/iglesia-santa-maria-de-la-asuncion/index.php [L]    
    RewriteRule ^lugares-interes/palacio-de-ocharan-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/palacio-de-ocharan/index.php [L]    
    RewriteRule ^lugares-interes/parque-amestoy-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/parque-amestoy/index.php [L]  
    RewriteRule ^lugares-interes/paseo-maritimo-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/paseo-maritimo/index.php [L]
    RewriteRule ^lugares-interes/plaza-del-ayuntamiento-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/plaza-del-ayuntamiento/index.php [L]
    RewriteRule ^lugares-interes/puente-medieval-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/puente-medieval/index.php [L]
    RewriteRule ^lugares-interes/puerto-pesquero-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/puerto-pesquero/index.php [L]
    
    # Sonabia
    RewriteRule ^sonabia-cantabria$             cantabria/sonabia/index.php [L]

    RewriteRule ^lugares-interes/playa-de-valdearenas-sonabia$  cantabria/sonabia/lugares-interes/playa-de-valdearenas/index.php [L]
    RewriteRule ^lugares-interes/pena-candina-sonabia$          cantabria/sonabia/lugares-interes/pena-candina/index.php [L]
