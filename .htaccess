<IfModule mod_rewrite.c>
    RewriteEngine On
    #RewriteBase /turismo-norte-espana/
    
    # Ajo
    #RewriteRule ^ajo-cantabria$                 cantabria/ajo/index.php [L]
    #RewriteRule ^ajo-cantabria$                 cantabria/ajo/index.php [L]
    
    
    #RewriteRule ^castro-urdiales-cantabria$     cantabria/castro-urdiales/index.php [L]



    RewriteRule ^lugares-interes/mirador-del-cabo-ajo$              cantabria/ajo/lugares-interes/mirador-del-cabo/index.php [L]
    RewriteRule ^lugares-interes/faro-de-cabo-de-ajo-ajo$           cantabria/ajo/lugares-interes/faro-de-cabo-de-ajo/index.php [L]
    RewriteRule ^lugares-interes/playa-de-cuberris-ajo$             cantabria/ajo/lugares-interes/playa-de-cuberris/index.php [L]
    RewriteRule ^lugares-interes/playa-de-antuerta-ajo$             cantabria/ajo/lugares-interes/playa-de-antuerta/index.php [L]
    RewriteRule ^lugares-interes/ruta-de-la-costa-oriental-ajo$     cantabria/ajo/lugares-interes/ruta-de-la-costa-oriental/index.php [L]
    RewriteRule ^lugares-interes/acantilados-de-cabo-de-ajo-ajo$    cantabria/ajo/lugares-interes/acantilados-de-cabo-de-ajo/index.php [L]
   
    RewriteRule ^mirador-del-cabo-ajo$ cantabria/ajo/lugares-interes/mirador-del-cabo/index.php [L]
    

    # Castro-Urdales
    RewriteRule ^lugares-interes/playa-de-ostende-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/playa-de-ostende/index.php [L]
    RewriteRule ^lugares-interes/playa-de-brazomar-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/playa-de-brazomar/index.php [L]
    RewriteRule ^lugares-interes/playa-de-el-pedregal-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/playa-de-el-pedregal/index.php [L]

    RewriteRule ^ruta-costera-ostende$         cantabria/playa-de-ostende/paginas-secundarias/senderos-costeros-senalizados/index.php [L]
    
    RewriteRule ^lugares-interes/mirador-de-cotolino-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/mirador-de-cotolino/index.php [L]
    


    RewriteRule ^lugares-interes/asador-la-perla-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/asador-la-perla/index.php [L]
    RewriteRule ^lugares-interes/castillo-de-santa-ana-castro-urdiales$ cantabria/castro-urdiales/lugares-interes/castillo-de-santa-ana/index.php [L]    
