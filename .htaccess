    ### Bizkaia ###
    # Bakio
    RewriteRule ^bakio-bizkaia$ /bizkaia/bakio/index.php [L]


    RewriteRule ^lugares-interes/playa-de-bakio-bakio$ /bizkaia/bakio/lugares-interes/playa-de-bakio/index.php [L]
